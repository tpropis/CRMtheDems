// ============================================================
// PRIVILEGE VAULT AI — Prisma Schema
// PostgreSQL + pgvector for embedding support
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Enums ────────────────────────────────────────────────────

enum UserRole {
  FIRM_OWNER
  MANAGING_PARTNER
  PARTNER
  ASSOCIATE
  PARALEGAL
  LEGAL_ASSISTANT
  INTAKE_COORDINATOR
  BILLING_ADMIN
  IT_ADMIN
  READ_ONLY_AUDITOR
}

enum MatterStatus {
  INTAKE
  ACTIVE
  ON_HOLD
  CLOSED
  ARCHIVED
}

enum MatterType {
  LITIGATION
  CORPORATE
  EMPLOYMENT
  REAL_ESTATE
  FAMILY_LAW
  CRIMINAL_DEFENSE
  IMMIGRATION
  INTELLECTUAL_PROPERTY
  BANKRUPTCY
  TAX
  ESTATE_PLANNING
  REGULATORY
  OTHER
}

enum IntakeStatus {
  NEW
  SCREENING
  CONFLICT_CHECK
  APPROVED
  REJECTED
  CONVERTED
  ABANDONED
}

enum ConflictStatus {
  PENDING
  CLEAR
  POTENTIAL_CONFLICT
  CONFLICT_CONFIRMED
  WAIVED
  REJECTED
}

enum DocumentStatus {
  DRAFT
  FINAL
  SUPERSEDED
  ARCHIVED
}

enum PrivilegeTag {
  ATTORNEY_CLIENT
  WORK_PRODUCT
  COMMON_INTEREST
  NEEDS_REVIEW
  NOT_PRIVILEGED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum CalendarEventType {
  HEARING
  DEPOSITION
  MEDIATION
  TRIAL
  DEADLINE
  FILING
  MEETING
  REMINDER
  COURT_DATE
  STATUS_CONFERENCE
  OTHER
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIAL
  OVERDUE
  VOID
  WRITE_OFF
}

enum TimeEntryStatus {
  DRAFT
  SUBMITTED
  APPROVED
  BILLED
  WRITTEN_OFF
}

enum AIJobStatus {
  QUEUED
  PROCESSING
  COMPLETE
  FAILED
  CANCELLED
}

enum AuditAction {
  LOGIN
  LOGIN_FAILED
  LOGOUT
  USER_CREATED
  USER_UPDATED
  USER_DEACTIVATED
  ROLE_CHANGED
  MATTER_CREATED
  MATTER_UPDATED
  MATTER_CLOSED
  MATTER_ACCESSED
  DOCUMENT_UPLOADED
  DOCUMENT_DOWNLOADED
  DOCUMENT_DELETED
  DOCUMENT_EXPORTED
  AI_QUERY
  AI_SOURCE_RETRIEVED
  RESEARCH_SAVED
  DRAFT_GENERATED
  DISCOVERY_UPLOADED
  DISCOVERY_TAGGED
  PRIVILEGE_FLAGGED
  TIME_ENTRY_CREATED
  INVOICE_GENERATED
  PAYMENT_RECORDED
  PERMISSION_CHANGED
  CONFLICT_CHECK_RUN
  INTAKE_CREATED
  INTAKE_CONVERTED
  EXPORT
  SETTINGS_CHANGED
  DELETE
  RESTORE
  LEGAL_HOLD_SET
}

// ── Core Firm Structure ──────────────────────────────────────

model Firm {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  domain      String?
  address     String?
  city        String?
  state       String?
  zipCode     String?
  country     String   @default("US")
  phone       String?
  website     String?
  barNumber   String?
  logoUrl     String?
  settings    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  offices     Office[]
  users       User[]
  clients     Client[]
  matters     Matter[]
  templates   Template[]
  workflows   Workflow[]
  integrations Integration[]
  auditEvents AuditEvent[]
  aiJobs      AIJob[]
}

model Office {
  id        String   @id @default(cuid())
  firmId    String
  name      String
  address   String?
  city      String?
  state     String?
  zipCode   String?
  phone     String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  firm    Firm     @relation(fields: [firmId], references: [id], onDelete: Cascade)
  users   User[]
  matters Matter[]
}

// ── Users & Auth ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  firmId        String
  officeId      String?
  email         String    @unique
  name          String
  title         String?
  role          UserRole  @default(ASSOCIATE)
  barNumber     String?
  phone         String?
  avatarUrl     String?
  passwordHash  String?
  isActive      Boolean   @default(true)
  isVerified    Boolean   @default(false)
  lastLoginAt   DateTime?
  mfaEnabled    Boolean   @default(false)
  mfaSecret     String?
  emailVerifiedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  firm            Firm              @relation(fields: [firmId], references: [id], onDelete: Cascade)
  office          Office?           @relation(fields: [officeId], references: [id])
  accounts        Account[]
  sessions        Session[]

  assignedMatters MatterParty[]
  documents       Document[]
  tasks           Task[]        @relation("TaskAssignee")
  createdTasks    Task[]        @relation("TaskCreator")
  timeEntries     TimeEntry[]
  researchThreads ResearchThread[]
  auditEvents     AuditEvent[]
  notifications   Notification[]
  savedSearches   SavedSearch[]
  reviewBatches   DiscoveryReviewBatch[]

  @@index([firmId])
  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Clients & Contacts ────────────────────────────────────────

model Client {
  id              String   @id @default(cuid())
  firmId          String
  clientNumber    String
  name            String
  type            String   @default("INDIVIDUAL") // INDIVIDUAL | ORGANIZATION
  email           String?
  phone           String?
  address         String?
  city            String?
  state           String?
  zipCode         String?
  country         String   @default("US")
  taxId           String?
  isActive        Boolean  @default(true)
  notes           String?  @db.Text
  inceptionDate   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  firm            Firm           @relation(fields: [firmId], references: [id], onDelete: Cascade)
  contacts        Contact[]
  matters         Matter[]
  intakeLeads     IntakeLead[]
  conflictEntries ConflictEntry[]

  @@unique([firmId, clientNumber])
  @@index([firmId])
}

model Contact {
  id           String   @id @default(cuid())
  firmId       String
  clientId     String?
  firstName    String
  lastName     String
  title        String?
  organization String?
  email        String?
  phone        String?
  address      String?
  city         String?
  state        String?
  zipCode      String?
  type         String   @default("CONTACT") // CONTACT | OPPOSING_COUNSEL | WITNESS | EXPERT | COURT | VENDOR
  notes        String?  @db.Text
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client          Client?         @relation(fields: [clientId], references: [id])
  matterParties   MatterParty[]
  conflictEntries ConflictEntry[]

  @@index([firmId])
}

// ── Matters ───────────────────────────────────────────────────

model Matter {
  id              String       @id @default(cuid())
  firmId          String
  officeId        String?
  clientId        String
  matterNumber    String
  name            String
  description     String?      @db.Text
  status          MatterStatus @default(ACTIVE)
  type            MatterType   @default(OTHER)
  practiceArea    String?
  jurisdiction    String?
  courtName       String?
  caseNumber      String?
  judgeAssigned   String?
  opposingCounsel String?
  riskLevel       String       @default("MEDIUM") // LOW | MEDIUM | HIGH | CRITICAL
  openedAt        DateTime     @default(now())
  closedAt        DateTime?
  statOfLimDate   DateTime?
  billingType     String       @default("HOURLY") // HOURLY | FLAT_FEE | CONTINGENCY | RETAINER
  billingRate     Decimal?     @db.Decimal(10, 2)
  retainerAmount  Decimal?     @db.Decimal(10, 2)
  estimatedFees   Decimal?     @db.Decimal(10, 2)
  tags            String[]     @default([])
  isLegalHold     Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  firm               Firm               @relation(fields: [firmId], references: [id], onDelete: Cascade)
  office             Office?            @relation(fields: [officeId], references: [id])
  client             Client             @relation(fields: [clientId], references: [id])
  parties            MatterParty[]
  documents          Document[]
  folders            Folder[]
  tasks              Task[]
  calendarEvents     CalendarEvent[]
  deadlines          Deadline[]
  timeEntries        TimeEntry[]
  invoices           Invoice[]
  researchThreads    ResearchThread[]
  discoveryCollections DiscoveryCollection[]
  intakeLead         IntakeLead?
  auditEvents        AuditEvent[]
  aiJobs             AIJob[]

  @@unique([firmId, matterNumber])
  @@index([firmId])
  @@index([clientId])
  @@index([status])
}

model MatterParty {
  id         String   @id @default(cuid())
  matterId   String
  userId     String?
  contactId  String?
  role       String   // RESPONSIBLE_ATTORNEY | BILLING_ATTORNEY | ASSOCIATE | PARALEGAL | ADVERSE_PARTY | WITNESS etc.
  isPrimary  Boolean  @default(false)
  addedAt    DateTime @default(now())

  matter  Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
  user    User?    @relation(fields: [userId], references: [id])
  contact Contact? @relation(fields: [contactId], references: [id])

  @@index([matterId])
}

// ── Intake & Conflicts ────────────────────────────────────────

model IntakeLead {
  id              String       @id @default(cuid())
  firmId          String
  clientId        String?
  matterId        String?      @unique
  leadNumber      String
  source          String?      // REFERRAL | WEBSITE | COLD_CALL | ADVERTISING | EXISTING_CLIENT
  prospectName    String
  prospectEmail   String?
  prospectPhone   String?
  prospectOrg     String?
  matterType      MatterType?
  jurisdiction    String?
  opposingParties String[]     @default([])
  urgency         String       @default("NORMAL") // LOW | NORMAL | HIGH | URGENT
  notes           String?      @db.Text
  status          IntakeStatus @default(NEW)
  assignedTo      String?
  convertedAt     DateTime?
  rejectionReason String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  client        Client?        @relation(fields: [clientId], references: [id])
  matter        Matter?        @relation(fields: [matterId], references: [id])
  conflictCheck ConflictCheck?

  @@index([firmId])
}

model ConflictCheck {
  id           String        @id @default(cuid())
  intakeLeadId String        @unique
  runAt        DateTime      @default(now())
  runById      String?
  status       ConflictStatus @default(PENDING)
  summary      String?       @db.Text
  approvedById String?
  approvedAt   DateTime?
  notes        String?       @db.Text
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  intakeLead IntakeLead      @relation(fields: [intakeLeadId], references: [id], onDelete: Cascade)
  results    ConflictResult[]
}

model ConflictResult {
  id              String  @id @default(cuid())
  conflictCheckId String
  entityType      String  // CLIENT | CONTACT | MATTER | OPPOSING_PARTY
  entityId        String?
  entityName      String
  matchType       String  // EXACT | FUZZY | RELATED
  confidence      Float   @default(0)
  reason          String?
  isConflict      Boolean @default(false)
  notes           String? @db.Text

  conflictCheck ConflictCheck @relation(fields: [conflictCheckId], references: [id], onDelete: Cascade)
}

model ConflictEntry {
  id        String @id @default(cuid())
  firmId    String
  clientId  String?
  contactId String?
  name      String
  type      String // CLIENT | ADVERSE_PARTY | WITNESS | ORGANIZATION
  notes     String? @db.Text
  addedAt   DateTime @default(now())

  client  Client?  @relation(fields: [clientId], references: [id])
  contact Contact? @relation(fields: [contactId], references: [id])
}

// ── Documents & Files ─────────────────────────────────────────

model Folder {
  id        String   @id @default(cuid())
  matterId  String?
  parentId  String?
  name      String
  path      String
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  matter    Matter?   @relation(fields: [matterId], references: [id], onDelete: Cascade)
  parent    Folder?   @relation("FolderTree", fields: [parentId], references: [id])
  children  Folder[]  @relation("FolderTree")
  documents Document[]
}

model Document {
  id             String         @id @default(cuid())
  firmId         String
  matterId       String?
  folderId       String?
  uploadedById   String
  name           String
  originalName   String
  mimeType       String
  size           Int
  storageKey     String         @unique
  status         DocumentStatus @default(DRAFT)
  version        Int            @default(1)
  isCurrentVersion Boolean      @default(true)
  description    String?        @db.Text
  tags           String[]       @default([])
  isPrivileged   Boolean        @default(false)
  privilegeTag   PrivilegeTag?
  isLegalHold    Boolean        @default(false)
  metadata       Json           @default("{}")
  extractedText  String?        @db.Text
  pageCount      Int?
  ocrProcessed   Boolean        @default(false)
  embeddingDone  Boolean        @default(false)
  checksum       String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  matter      Matter?          @relation(fields: [matterId], references: [id])
  folder      Folder?          @relation(fields: [folderId], references: [id])
  uploadedBy  User             @relation(fields: [uploadedById], references: [id])
  versions    DocumentVersion[]
  tags_rel    DocumentTag[]
  chunks      RetrievalChunk[]
  embeddings  EmbeddingRecord[]
  privilegeFlags PrivilegeFlag[]
  discoveryDocs  DiscoveryDocument[]

  @@index([firmId])
  @@index([matterId])
  @@index([uploadedById])
}

model DocumentVersion {
  id           String   @id @default(cuid())
  documentId   String
  version      Int
  storageKey   String
  size         Int
  uploadedById String
  changeNote   String?
  createdAt    DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model DocumentTag {
  id         String   @id @default(cuid())
  documentId String
  tag        String
  addedById  String?
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, tag])
}

// ── Research ──────────────────────────────────────────────────

model ResearchThread {
  id          String   @id @default(cuid())
  matterId    String?
  userId      String
  title       String
  summary     String?  @db.Text
  isSaved     Boolean  @default(false)
  tags        String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  matter   Matter?           @relation(fields: [matterId], references: [id])
  user     User              @relation(fields: [userId], references: [id])
  messages ResearchMessage[]
  sources  ResearchSource[]

  @@index([matterId])
  @@index([userId])
}

model ResearchMessage {
  id          String   @id @default(cuid())
  threadId    String
  role        String   // USER | ASSISTANT | SYSTEM
  content     String   @db.Text
  modelUsed   String?
  confidence  Float?
  tokens      Int?
  latencyMs   Int?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  thread    ResearchThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  citations Citation[]

  @@index([threadId])
}

model ResearchSource {
  id          String   @id @default(cuid())
  threadId    String
  documentId  String?
  sourceType  String   // MATTER_DOCUMENT | KNOWLEDGE_BASE | UPLOADED
  title       String
  description String?  @db.Text
  url         String?
  pageNumber  Int?
  excerpt     String?  @db.Text
  relevance   Float?
  createdAt   DateTime @default(now())

  thread ResearchThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
}

model Citation {
  id          String   @id @default(cuid())
  messageId   String
  caseTitle   String
  citation    String
  court       String?
  year        Int?
  excerpt     String?  @db.Text
  isVerified  Boolean  @default(false)
  confidence  Float?
  createdAt   DateTime @default(now())

  message ResearchMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

// ── Discovery ─────────────────────────────────────────────────

model DiscoveryCollection {
  id          String   @id @default(cuid())
  matterId    String
  name        String
  description String?  @db.Text
  productionDate DateTime?
  producingParty String?
  batesPrefix String?
  batesStart  Int?
  batesEnd    Int?
  status      String   @default("ACTIVE") // ACTIVE | ARCHIVED
  totalDocs   Int      @default(0)
  reviewedDocs Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  matter    Matter                @relation(fields: [matterId], references: [id], onDelete: Cascade)
  documents DiscoveryDocument[]
  batches   DiscoveryReviewBatch[]

  @@index([matterId])
}

model DiscoveryDocument {
  id             String      @id @default(cuid())
  collectionId   String
  documentId     String?
  batesNumber    String?
  custodian      String?
  docDate        DateTime?
  docType        String?
  subject        String?
  author         String?
  recipients     String[]    @default([])
  isRelevant     Boolean?
  isHot          Boolean     @default(false)
  isPrivileged   Boolean?
  privilegeTag   PrivilegeTag?
  privilegeNotes String?     @db.Text
  reviewStatus   String      @default("UNREVIEWED") // UNREVIEWED | IN_REVIEW | REVIEWED
  reviewedById   String?
  reviewedAt     DateTime?
  batchId        String?
  tags           DiscoveryTag[]
  notes          String?     @db.Text
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  collection DiscoveryCollection  @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  document   Document?            @relation(fields: [documentId], references: [id])
  batch      DiscoveryReviewBatch? @relation(fields: [batchId], references: [id])

  @@index([collectionId])
}

model DiscoveryTag {
  id         String            @id @default(cuid())
  documentId String
  tag        String
  addedById  String?
  confidence Float?
  isAI       Boolean @default(false)
  createdAt  DateTime @default(now())

  document DiscoveryDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model DiscoveryReviewBatch {
  id           String   @id @default(cuid())
  collectionId String
  assignedToId String?
  name         String
  description  String?
  status       String   @default("OPEN") // OPEN | IN_PROGRESS | COMPLETE
  targetCount  Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  collection DiscoveryCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  assignedTo User?               @relation(fields: [assignedToId], references: [id])
  documents  DiscoveryDocument[]
}

model PrivilegeFlag {
  id          String       @id @default(cuid())
  documentId  String
  matterId    String?
  flaggedById String?
  tag         PrivilegeTag
  notes       String?      @db.Text
  isAI        Boolean      @default(false)
  confidence  Float?
  isOverridden Boolean     @default(false)
  overrideNote String?     @db.Text
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model PrivilegeLogEntry {
  id              String       @id @default(cuid())
  matterId        String
  documentId      String?
  batesNumber     String?
  docDate         DateTime?
  author          String?
  recipients      String[]     @default([])
  description     String?      @db.Text
  privilegeTag    PrivilegeTag
  basis           String?      @db.Text
  withheld        Boolean      @default(true)
  redacted        Boolean      @default(false)
  createdById     String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

// ── Calendar & Deadlines ──────────────────────────────────────

model CalendarEvent {
  id          String            @id @default(cuid())
  firmId      String
  matterId    String?
  createdById String?
  title       String
  description String?           @db.Text
  eventType   CalendarEventType @default(OTHER)
  startAt     DateTime
  endAt       DateTime?
  allDay      Boolean           @default(false)
  location    String?
  isRecurring Boolean           @default(false)
  recurrence  Json?
  attendees   String[]          @default([])
  reminders   Json              @default("[]")
  metadata    Json              @default("{}")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  matter Matter? @relation(fields: [matterId], references: [id])

  @@index([firmId])
  @@index([matterId])
  @@index([startAt])
}

model Deadline {
  id           String   @id @default(cuid())
  firmId       String
  matterId     String
  title        String
  description  String?  @db.Text
  dueAt        DateTime
  deadlineType String   @default("GENERAL") // STATUTE_OF_LIMITATIONS | FILING | COURT | RESPONSE | DISCOVERY | GENERAL
  ruleSource   String?
  isCalculated Boolean  @default(false)
  parentId     String?
  priority     TaskPriority @default(MEDIUM)
  isCompleted  Boolean  @default(false)
  completedAt  DateTime?
  isEscalated  Boolean  @default(false)
  assignedTo   String[]  @default([])
  reminders    Json     @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  matter Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  @@index([firmId])
  @@index([matterId])
  @@index([dueAt])
}

// ── Tasks ─────────────────────────────────────────────────────

model Task {
  id          String       @id @default(cuid())
  firmId      String
  matterId    String?
  createdById String
  assigneeId  String?
  title       String
  description String?      @db.Text
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueAt       DateTime?
  completedAt DateTime?
  linkedType  String?      // DOCUMENT | DEADLINE | CALENDAR_EVENT
  linkedId    String?
  tags        String[]     @default([])
  position    Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  matter    Matter?       @relation(fields: [matterId], references: [id])
  createdBy User          @relation("TaskCreator", fields: [createdById], references: [id])
  assignee  User?         @relation("TaskAssignee", fields: [assigneeId], references: [id])
  comments  TaskComment[]

  @@index([firmId])
  @@index([matterId])
  @@index([assigneeId])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

// ── Time & Billing ────────────────────────────────────────────

model TimeEntry {
  id          String          @id @default(cuid())
  firmId      String
  matterId    String
  userId      String
  invoiceId   String?
  description String          @db.Text
  hoursWorked Decimal         @db.Decimal(6, 2)
  ratePerHour Decimal         @db.Decimal(10, 2)
  amount      Decimal         @db.Decimal(12, 2)
  status      TimeEntryStatus @default(DRAFT)
  billingDate DateTime        @default(now())
  taskId      String?
  documentId  String?
  threadId    String?
  isBillable  Boolean         @default(true)
  writeOff    Decimal?        @db.Decimal(12, 2)
  writeOffNote String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  matter  Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id])
  invoice Invoice? @relation(fields: [invoiceId], references: [id])

  @@index([firmId])
  @@index([matterId])
  @@index([userId])
}

model Invoice {
  id              String        @id @default(cuid())
  firmId          String
  matterId        String
  invoiceNumber   String
  status          InvoiceStatus @default(DRAFT)
  issueDate       DateTime      @default(now())
  dueDate         DateTime?
  periodStart     DateTime?
  periodEnd       DateTime?
  subtotal        Decimal       @db.Decimal(12, 2)
  taxRate         Decimal?      @db.Decimal(5, 4)
  taxAmount       Decimal?      @db.Decimal(12, 2)
  total           Decimal       @db.Decimal(12, 2)
  amountPaid      Decimal       @db.Decimal(12, 2) @default(0)
  balance         Decimal       @db.Decimal(12, 2)
  notes           String?       @db.Text
  sentAt          DateTime?
  paidAt          DateTime?
  voidedAt        DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  matter    Matter          @relation(fields: [matterId], references: [id])
  lineItems InvoiceLineItem[]
  payments  Payment[]
  timeEntries TimeEntry[]

  @@unique([firmId, invoiceNumber])
  @@index([firmId])
  @@index([matterId])
}

model InvoiceLineItem {
  id          String   @id @default(cuid())
  invoiceId   String
  description String   @db.Text
  quantity    Decimal  @db.Decimal(8, 2)
  unitPrice   Decimal  @db.Decimal(10, 2)
  amount      Decimal  @db.Decimal(12, 2)
  timeEntryId String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Payment {
  id            String   @id @default(cuid())
  invoiceId     String
  amount        Decimal  @db.Decimal(12, 2)
  method        String   @default("CHECK") // CHECK | WIRE | ACH | CREDIT_CARD | TRUST
  reference     String?
  note          String?
  paidAt        DateTime @default(now())
  recordedById  String?
  createdAt     DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])
}

model TrustLedgerEntry {
  id          String   @id @default(cuid())
  firmId      String
  matterId    String
  clientId    String?
  amount      Decimal  @db.Decimal(12, 2)
  type        String   // DEPOSIT | WITHDRAWAL | TRANSFER | FEE
  description String   @db.Text
  balance     Decimal  @db.Decimal(12, 2)
  reference   String?
  entryDate   DateTime @default(now())
  createdById String?
  createdAt   DateTime @default(now())

  @@index([firmId])
  @@index([matterId])
}

// ── Templates & Clauses ───────────────────────────────────────

model Template {
  id           String   @id @default(cuid())
  firmId       String
  name         String
  description  String?  @db.Text
  category     String   // MOTION | CONTRACT | LETTER | MEMO | DISCOVERY | ENGAGEMENT
  practiceArea String?
  content      String   @db.Text
  variables    Json     @default("[]")
  isPublic     Boolean  @default(false)
  isSystem     Boolean  @default(false)
  createdById  String?
  usageCount   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@index([firmId])
}

model Clause {
  id           String   @id @default(cuid())
  firmId       String
  title        String
  content      String   @db.Text
  category     String
  practiceArea String?
  tags         String[] @default([])
  isActive     Boolean  @default(true)
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ── Workflows ─────────────────────────────────────────────────

model Workflow {
  id           String   @id @default(cuid())
  firmId       String
  name         String
  description  String?  @db.Text
  trigger      String   // MATTER_CREATED | INTAKE_CONVERTED | DEADLINE_ADDED
  practiceArea String?
  steps        Json     @default("[]")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  firm Firm          @relation(fields: [firmId], references: [id], onDelete: Cascade)
  runs WorkflowRun[]
}

model WorkflowRun {
  id          String   @id @default(cuid())
  workflowId  String
  matterId    String?
  status      String   @default("RUNNING") // RUNNING | COMPLETE | FAILED
  startedAt   DateTime @default(now())
  completedAt DateTime?
  error       String?
  context     Json     @default("{}")

  workflow Workflow @relation(fields: [workflowId], references: [id])
}

// ── AI Infrastructure ─────────────────────────────────────────

model AIJob {
  id          String      @id @default(cuid())
  firmId      String
  matterId    String?
  documentId  String?
  type        String      // INGEST | EMBED | SUMMARIZE | EXTRACT | PRIVILEGE_TAG | OCR | CHRONOLOGY
  status      AIJobStatus @default(QUEUED)
  provider    String?
  model       String?
  input       Json        @default("{}")
  output      Json?
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  tokens      Int?
  costEstimate Decimal?   @db.Decimal(10, 6)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  firm   Firm    @relation(fields: [firmId], references: [id])
  matter Matter? @relation(fields: [matterId], references: [id])

  @@index([firmId])
  @@index([status])
}

model RetrievalChunk {
  id          String   @id @default(cuid())
  documentId  String
  chunkIndex  Int
  content     String   @db.Text
  metadata    Json     @default("{}")
  tokenCount  Int?
  createdAt   DateTime @default(now())

  document   Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  embeddings EmbeddingRecord[]

  @@index([documentId])
}

model EmbeddingRecord {
  id          String                      @id @default(cuid())
  chunkId     String?
  documentId  String?
  firmId      String
  matterId    String?
  content     String                      @db.Text
  embedding   String?  @db.Text  // Stored as JSON array; replace with Unsupported("vector(1536)") if pgvector is available
  model       String
  dimensions  Int
  metadata    Json                        @default("{}")
  createdAt   DateTime                    @default(now())

  chunk    RetrievalChunk? @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  document Document?       @relation(fields: [documentId], references: [id])

  @@index([firmId])
  @@index([matterId])
}

// ── Audit & Compliance ─────────────────────────────────────────

model AuditEvent {
  id          String      @id @default(cuid())
  firmId      String
  userId      String?
  matterId    String?
  action      AuditAction
  resource    String?
  resourceId  String?
  description String?     @db.Text
  metadata    Json        @default("{}")
  ipAddress   String?
  userAgent   String?
  sessionId   String?
  createdAt   DateTime    @default(now())

  firm   Firm    @relation(fields: [firmId], references: [id])
  user   User?   @relation(fields: [userId], references: [id])
  matter Matter? @relation(fields: [matterId], references: [id])

  @@index([firmId])
  @@index([userId])
  @@index([matterId])
  @@index([action])
  @@index([createdAt])
}

// ── Notifications ─────────────────────────────────────────────

model Notification {
  id         String   @id @default(cuid())
  userId     String
  title      String
  body       String   @db.Text
  type       String   @default("INFO") // INFO | WARNING | URGENT | ACTION_REQUIRED
  link       String?
  isRead     Boolean  @default(false)
  readAt     DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model SavedSearch {
  id        String   @id @default(cuid())
  userId    String
  name      String
  query     Json
  scope     String   // MATTERS | DOCUMENTS | RESEARCH | DISCOVERY | GLOBAL
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Integration {
  id          String   @id @default(cuid())
  firmId      String
  type        String   // CALENDAR | EMAIL | COURT_DOCKET | E_SIGNATURE | ACCOUNTING
  name        String
  config      Json     @default("{}")
  isActive    Boolean  @default(false)
  lastSyncAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)
}
